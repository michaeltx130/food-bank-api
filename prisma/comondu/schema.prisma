generator client {
  provider = "prisma-client-js"
  output   = "../../src/generated/comondu"
}

datasource db {
  provider = "mysql"
}

model beneficiarios {
  id       Int        @id @default(autoincrement())
  nombre   String?
  entregas entregas[]
  familia  familias?
}

model categorias {
  id          Int           @id @default(autoincrement()) @db.TinyInt
  nombre      String
  productos   productos[]
}

model donantes {
  id       Int     @id @default(autoincrement())
  nombre   String?
  telefono String?
}

model familias {
  id                Int           @id @default(autoincrement())
  beneficiario_id   Int           @unique
  nombre            String?
  telefono          String?
  cantidad_miembros Int?
  direccion         String?
  beneficiario      beneficiarios @relation(fields: [beneficiario_id], references: [id])
}

model donaciones {
  id          Int        @id @default(autoincrement())
  donante     String?
  producto_id Int?
  cantidad    Int?
  fecha       DateTime?  @default(now())
  producto    productos? @relation(fields: [producto_id], references: [id])
}

model entregas {
  id              Int            @id @default(autoincrement())
  beneficiario_id Int?
  producto_id     Int?
  cantidad        Int?
  fecha           DateTime?      @default(now())
  beneficiario    beneficiarios? @relation(fields: [beneficiario_id], references: [id])
  producto        productos?     @relation(fields: [producto_id], references: [id])
}

model movimientos {
  id          Int        @id @default(autoincrement())
  producto_id Int?
  tipo        String?
  cantidad    Int?
  fecha       DateTime?  @default(now())
  producto    productos? @relation(fields: [producto_id], references: [id])
}

model productos {
  id           Int           @id @default(autoincrement())
  nombre       String?
  categoria_id Int?          @db.TinyInt
  cantidad     Int?
  unit         String        @default("pz") @db.VarChar(20)
  categoria    categorias?   @relation(fields: [categoria_id], references: [id])
  donaciones   donaciones[]
  entregas     entregas[]
  movimientos  movimientos[]
  transferencias transferencias[]
}

model transferencias {
  id              Int        @id @default(autoincrement())
  transferencia_id String?   @unique @db.VarChar(80)
  producto_id      Int?
  producto_nombre  String?   @db.VarChar(100)
  categoria_id     Int?
  cantidad         Int       @default(0)
  origen           String?   @db.VarChar(100)
  destino          String?   @db.VarChar(100)
  estado           String    @default("PENDIENTE") @db.VarChar(30)
  evento_id        String?   @db.VarChar(80)
  error            String?   @db.Text
  created_at       DateTime? @default(now())
  updated_at       DateTime? @default(now()) @updatedAt
  producto         productos? @relation(fields: [producto_id], references: [id])
}
