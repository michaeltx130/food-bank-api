generator client {
  provider = "prisma-client-js"
  output   = "../../src/generated/comondu"
}

datasource db {
  provider = "mysql"
}

model beneficiarios {
  id       Int        @id @default(autoincrement())
  nombre   String?
  entregas entregas[]
  familia  familias?
}

model categorias {
  id          Int           @id @default(autoincrement()) @db.TinyInt
  nombre      String
  productos   productos[]
}

model donantes {
  id       Int     @id @default(autoincrement())
  nombre   String?
  telefono String?
}

model familias {
  id                Int           @id @default(autoincrement())
  beneficiario_id   Int           @unique
  nombre            String?
  telefono          String?
  cantidad_miembros Int?
  direccion         String?
  beneficiario      beneficiarios @relation(fields: [beneficiario_id], references: [id])
}

model entregas {
  id              Int            @id @default(autoincrement())
  beneficiario_id Int?
  producto_id     Int?
  cantidad        Int?
  fecha           DateTime?      @default(now())
  beneficiario    beneficiarios? @relation(fields: [beneficiario_id], references: [id])
  producto        productos?     @relation(fields: [producto_id], references: [id])
}

model movimientos {
  id          Int        @id @default(autoincrement())
  producto_id Int?
  tipo        String?
  cantidad    Int?
  fecha       DateTime?  @default(now())
  producto    productos? @relation(fields: [producto_id], references: [id])
}

model productos {
  id           Int           @id @default(autoincrement())
  nombre       String?
  categoria_id Int?          @db.TinyInt
  cantidad     Int?
  unit         String        @default("pz") @db.VarChar(20)
  categoria    categorias?   @relation(fields: [categoria_id], references: [id])
  entregas     entregas[]
  movimientos  movimientos[]
}
